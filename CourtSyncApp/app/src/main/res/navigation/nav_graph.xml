<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.courtsync.app.fragments.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_home_to_details"
            app:destination="@id/sportHallDetailsFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <action
            android:id="@+id/action_home_to_ai"
            app:destination="@id/aiFragment" />
    </fragment>

    <fragment
        android:id="@+id/searchFragment"
        android:name="com.courtsync.app.fragments.SearchFragment"
        android:label="Search"
        tools:layout="@layout/fragment_search">
        <action
            android:id="@+id/action_search_to_details"
            app:destination="@id/sportHallDetailsFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/reservationsFragment"
        android:name="com.courtsync.app.fragments.ReservationsFragment"
        android:label="Bookings"
        tools:layout="@layout/fragment_reservations" />

    <fragment
        android:id="@+id/aiFragment"
        android:name="com.courtsync.app.fragments.AIFragment"
        android:label="AI Coach"
        tools:layout="@layout/fragment_ai" />

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.courtsync.app.fragments.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_profile" />

    <fragment
        android:id="@+id/sportHallDetailsFragment"
        android:name="com.courtsync.app.fragments.SportHallDetailsFragment"
        android:label="Hall Details"
        tools:layout="@layout/fragment_sport_hall_details">
        <argument
            android:name="hallId"
            app:argType="long" />
        <action
            android:id="@+id/action_details_to_reservation"
            app:destination="@id/reservationsFragment"
            app:launchSingleTop="true"
            app:popUpTo="@id/homeFragment"
            app:popUpToInclusive="false" />
    </fragment>

</navigation>
