        <item name="android:textColor">@color/foreground</item>
        <item name="materialCardViewStyle">@style/CardView.CourtSync</item>
        <item name="bottomNavigationStyle">@style/BottomNav.CourtSync</item>
        <item name="textInputStyle">@style/TextInput.CourtSync</item>
    </style>
    <style name="Theme.CourtSync.Splash" parent="Theme.CourtSync">
        <item name="android:windowFullscreen">true</item>
    </style>
